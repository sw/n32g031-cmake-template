{
    "configurePresets": [
        {
            "binaryDir": "${sourceDir}/build/${presetName}",
            "generator": "Ninja",
            "hidden": true,
            "name": "common"
        },
        {
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            },
            "inherits": "common",
            "name": "Debug"
        },
        {
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            },
            "inherits": "common",
            "name": "Release"
        }
    ],
    "version": 3
}
